# CS Multi-Model Trading System environment
# Copy to .env for local runs. Do not commit .env.

# Alpaca paper trading / market data
ALPACA_API_KEY=xxxxx
ALPACA_API_SECRET=xxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets
TRADING_ENV=paper

# Optional point-in-time fundamentals and news analysis
FMP_API_KEY=xxxxx
ANTHROPIC_API_KEY=xxxxx

# Runtime output directories
CS_LOG_DIR=logs
MPLCONFIGDIR=/tmp/matplotlib
